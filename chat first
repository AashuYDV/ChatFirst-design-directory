window.editProfileField = function(key, valId) {
  const span = document.getElementById(valId);
  if (!span) return;
  const current = span.textContent;
  const inp = document.createElement('input');
  inp.className = 'profile-edit-inp';
  inp.value = current;
  inp.style.flex = '1';
  span.replaceWith(inp);
  inp.focus();
  const save = () => {
    const newVal = inp.value.trim() || current;
    const newSpan = document.createElement('span');
    newSpan.className = 'profile-field-value';
    newSpan.id = valId;
    newSpan.textContent = newVal;
    inp.replaceWith(newSpan);
    if (window._answers) window._answers[key] = newVal;
    /* update subtitle */
    const sub = document.querySelector('.profile-card-subtitle');
    if (sub && window._answers) {
      sub.textContent = `${window._answers.domain||''} · ${window._answers.experience||''} · ${window._answers.ctc||''}`;
    }
  };
  inp.addEventListener('keypress', e => { if (e.key === 'Enter') save(); });
  inp.addEventListener('blur', save);
};

