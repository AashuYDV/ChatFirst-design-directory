const _observer = new MutationObserver(() => {
  const arc = document.getElementById('arc-fg');
  if (arc && !arc.dataset.animated) {
    arc.dataset.animated = '1';
    // circumference = 2π×30 = 188.4; 30/70 ≈ 42.8%
    // dashoffset = 188.4 × (1 − 0.428) = 188.4 × 0.572 ≈ 107.8
    setTimeout(() => { arc.style.strokeDashoffset = '107.8'; }, 120);
  }
});
_observer.observe(document.getElementById('chat-feed'), { childList: true, subtree: true });

