<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Leap — Your Career Abroad Starts Here</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ============================================================
       LEAP DESIGN TOKENS (Official v1)
       Source: Leap Design System CSS Tokens
    ============================================================ */
    :root {
      /* ── Brand ── */
      --brand-primary:        #4A47FF;
      --brand-primary-light:  #F4F3FF;
      --brand-primary-200:    #CAC9FF;
      --brand-primary-300:    #B0AEFF;
      --brand-primary-dark:   #232270;
      --brand-secondary:      #FB743A;

      /* ── Neutrals ── */
      --neutral-100:  #FBFCFD;
      --neutral-200:  #F3F5F7;
      --neutral-300:  #E2E6EA;
      --neutral-400:  #C6CBD2;
      --neutral-500:  #A6ADB8;
      --neutral-700:  #656E7F;
      --neutral-900:  #1C2233;
      --white:        #FFFFFF;
      --black:        #000000;

      /* ── Specialty ── */
      --primary-1000: #100F33;   /* Darkest primary / dark BG */
      --blue-700:     #050D17;

      /* ── Feedback ── */
      --success:        #3A9E59;
      --success-light:  #F0FAF3;
      --success-300:    #A9E4BE;
      --warning:        #D99429;
      --warning-light:  #FFF8E6;
      --error:          #C63A3A;
      --error-light:    #FDF2F2;
      --info:           #3A74D4;
      --info-light:     #F1F7FF;

      /* ── Typography ── */
      --font-heading: 'Plus Jakarta Sans', sans-serif;
      --font-body:    'Inter', sans-serif;
      --fw-regular:   400;
      --fw-medium:    500;
      --fw-semibold:  600;
      --fw-bold:      700;

      /* ── Shadows (official) ── */
      --shadow-sm:    0 2px 4px rgba(28,33,51,0.10);
      --shadow-md:    0 3px 10px rgba(28,34,51,0.12);
      --shadow-lg:    0 4px 20px rgba(28,34,51,0.18);
      --shadow-xl:    0 8px 48px rgba(28,34,51,0.25);
      --shadow-hover: 0 4px 20px #B0AEFF;

      /* ── Border radius (official) ── */
      --radius-sm:  4px;
      --radius-lg:  8px;
      --radius-xl:  12px;
      --radius-2xl: 16px;
      --radius-3xl: 20px;
      --radius-4xl: 24px;
      --radius-5xl: 32px;
      --radius-6xl: 48px;

      /* ── Semantic aliases (used throughout) ── */
      --primary:        var(--brand-primary);
      --primary-hover:  var(--brand-primary-dark);
      --primary-light:  var(--brand-primary-light);
      --secondary:      var(--brand-secondary);
      --secondary-light:rgba(251,116,58,0.12);

      --bg-dark:        var(--primary-1000);
      --bg-surface:     #1A1950;            /* dark card surface */
      --bg-page:        var(--neutral-200);
      --bg-white:       var(--white);

      --text-on-dark:     var(--white);
      --text-body:        var(--neutral-900);
      --text-sub:         var(--neutral-700);
      --text-muted:       var(--neutral-500);
      --text-on-dark-sub: rgba(255,255,255,0.62);

      --chat-bot-bg:  var(--white);
      --chat-user-bg: var(--brand-primary);

      --border-light: var(--neutral-300);
      --border-card:  var(--neutral-200);

      /* Legacy radius aliases */
      --r-sm:   var(--radius-lg);    /* 8px  */
      --r-md:   var(--radius-xl);    /* 12px */
      --r-lg:   var(--radius-2xl);   /* 16px */
      --r-xl:   var(--radius-4xl);   /* 24px */
      --r-full: 9999px;

      /* Legacy shadow aliases */
      --sh-sm:      var(--shadow-sm);
      --sh-md:      var(--shadow-md);
      --sh-lg:      var(--shadow-lg);
      --sh-primary: 0 4px 20px rgba(74,71,255,0.36);
    }

    /* ============================================================
       RESET & BASE
    ============================================================ */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { font-size: 16px; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #0C0B2A;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      overflow: hidden;
      /* Desktop ambient glow */
      background-image:
        radial-gradient(ellipse 600px 400px at 30% 50%, rgba(74,71,255,0.12) 0%, transparent 70%),
        radial-gradient(ellipse 400px 300px at 75% 60%, rgba(251,116,58,0.08) 0%, transparent 70%);
    }

    /* ============================================================
       SCREEN SHELL (390px mobile frame)
    ============================================================ */
    .screen {
      width: 390px;
      height: 100vh;
      position: relative;
      display: none;
      flex-direction: column;
      overflow: hidden;
      background: var(--bg-dark);
    }
    .screen.active { display: flex; }

    /* ============================================================
       SCREEN 1 — LANDING PAGE
    ============================================================ */
    /* Landing: height:100vh + overflow-y:auto = scrolls internally.
       display is controlled by .screen (none) / .screen.active (flex).
       We override .screen.active to block (not flex) for natural scrolling. */
    #screen-landing {
      height: 100vh;
      overflow-y: auto;
      overflow-x: hidden;
      background: #F8F7F3;
    }
    #screen-landing.active { display: block; }
    #screen-landing::-webkit-scrollbar { display: none; }

    /* Hero fold — light cream background matching LeapScholar design language */
    .hero {
      padding: 0 22px 36px;
      position: relative;
      overflow: hidden;
      flex-shrink: 0;
      background: #F8F7F3;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -80px; right: -60px;
      width: 220px; height: 220px;
      background: radial-gradient(circle, rgba(74,71,255,0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero::after { display: none; }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: rgba(74,71,255,0.08);
      border: 1px solid rgba(74,71,255,0.18);
      border-radius: var(--r-full);
      padding: 5px 12px;
      font-size: 10.5px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      color: var(--brand-primary);
      margin-bottom: 20px;
      position: relative;
      z-index: 1;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .hero-eyebrow-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--secondary);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(0.8); }
    }

    .hero-h1 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 34px;
      font-weight: 800;
      line-height: 1.16;
      color: var(--primary-1000);
      margin-bottom: 16px;
      position: relative;
      z-index: 1;
      letter-spacing: -0.02em;
    }
    .hero-h1 .accent { color: var(--brand-primary); }
    .hero-h1 .glow { color: var(--brand-secondary); }

    .hero-sub {
      font-size: 14.5px;
      line-height: 1.65;
      color: var(--neutral-700);
      margin-bottom: 22px;
      position: relative;
      z-index: 1;
    }

    .hero-bullets {
      list-style: none;
      margin-bottom: 22px;
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .hero-bullets li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13.5px;
      color: var(--neutral-900);
      font-weight: 500;
    }
    .bullet-check {
      width: 20px; height: 20px;
      background: rgba(74,71,255,0.1);
      border: none;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      color: var(--brand-primary);
      flex-shrink: 0;
      font-weight: 700;
    }

    /* CTA stack */
    .cta-stack {
      display: flex;
      flex-direction: column;
      gap: 10px;
      position: relative;
      z-index: 1;
    }
    .btn-primary {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 16px 20px;
      background: var(--primary);
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      border: none;
      border-radius: var(--r-md);
      cursor: pointer;
      box-shadow: var(--sh-primary);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      letter-spacing: -0.01em;
    }
    .btn-primary:active { transform: scale(0.98); box-shadow: 0 2px 8px rgba(74,71,255,0.3); }

    .btn-ghost {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 15px 20px;
      background: transparent;
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 600;
      border: 1.5px solid rgba(255,255,255,0.22);
      border-radius: var(--r-md);
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn-ghost:active { background: rgba(255,255,255,0.06); }

    /* ── Landing nav ── */
    .land-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 0 0;
      position: relative;
      z-index: 2;
    }
    .land-logo {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .land-logo-icon {
      width: 28px; height: 28px;
      background: var(--brand-primary);
      border-radius: 7px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .land-logo-icon svg { display: block; }
    .land-logo-text {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 17px;
      font-weight: 800;
      color: var(--primary-1000);
      letter-spacing: -0.02em;
    }
    .land-signin {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--neutral-700);
      cursor: pointer;
      padding: 6px 14px;
      border: 1px solid var(--neutral-300);
      border-radius: var(--r-full);
      transition: color 0.15s, border-color 0.15s;
      background: #fff;
    }
    .land-signin:hover { color: var(--primary-1000); border-color: var(--neutral-400); }

    /* ── Single eligibility CTA ── */
    .hero-cta-group {
      position: relative;
      z-index: 1;
      margin-top: 4px;
    }
    .btn-eligibility {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 17px 20px;
      background: var(--brand-secondary);
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 16px;
      font-weight: 700;
      border: none;
      border-radius: var(--r-xl);
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(251,116,58,0.45);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      letter-spacing: -0.01em;
    }
    .btn-eligibility:active { transform: scale(0.98); }
    .btn-eligibility-arrow {
      width: 28px; height: 28px;
      background: rgba(255,255,255,0.22);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    .hero-cta-sub {
      text-align: center;
      font-size: 12px;
      color: var(--neutral-500);
      margin-top: 10px;
    }

    /* ── Hero stats row (inside fold 1, above CTA) ── */
    .hero-stats {
      display: flex;
      gap: 0;
      margin-bottom: 22px;
      position: relative;
      z-index: 1;
      background: #fff;
      border-radius: var(--radius-xl);
      border: 1px solid var(--neutral-300);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
    }
    .hstat {
      flex: 1;
      text-align: center;
      padding: 12px 6px;
      border-right: 1px solid var(--neutral-300);
    }
    .hstat:last-child { border-right: none; }
    .hstat-n {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 20px;
      font-weight: 800;
      color: var(--primary-1000);
      line-height: 1;
    }
    .hstat-n .hstat-accent { color: var(--brand-secondary); }
    .hstat-l {
      font-size: 10px;
      color: var(--neutral-700);
      margin-top: 4px;
      line-height: 1.3;
    }

    /* ── Social proof mini (below CTA, still in fold 1) ── */
    .proof-mini {
      margin-top: 12px;
      position: relative;
      z-index: 1;
    }
    .proof-mini-avatars {
      display: flex;
      align-items: center;
      margin-bottom: 10px;
    }
    .pm-avatar {
      width: 32px; height: 32px;
      border-radius: 50%;
      border: 2px solid #F8F7F3;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 11px;
      font-weight: 800;
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      margin-left: -8px;
      flex-shrink: 0;
    }
    .pm-avatar:first-child { margin-left: 0; }
    .pm-count {
      margin-left: 10px;
      font-size: 12px;
      color: var(--neutral-700);
    }
    .pm-count strong {
      color: var(--primary-1000);
      font-weight: 700;
    }
    .proof-mini-quote-unused {
      font-size: 12.5px;
      color: var(--neutral-700);
      line-height: 1.5;
      font-style: italic;
      border-left: 2px solid var(--brand-secondary);
      padding-left: 10px;
    }
    .proof-mini-quote span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      font-style: normal;
      color: var(--neutral-500);
      font-weight: 500;
    }

    /* ── Trust micro-copy ── */
    .trust-line {
      text-align: center;
      font-size: 11px;
      color: var(--neutral-500);
      margin-top: 8px;
      position: relative;
      z-index: 1;
    }

    /* ── Fold 2 — Social proof ── */
    .proof-fold {
      background: var(--white);
      padding: 32px 0 44px;
      flex-shrink: 0;
      border-top: 1px solid var(--neutral-300);
    }
    .proof-heading {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 19px;
      font-weight: 800;
      color: var(--primary-1000);
      margin-bottom: 4px;
      padding: 0 22px;
    }
    .proof-sub-head {
      font-size: 13px;
      color: var(--text-sub);
      padding: 0 22px;
      margin-bottom: 20px;
    }

    /* Testimonials — HORIZONTAL SCROLL */
    .testimonials {
      display: flex;
      flex-direction: row;
      gap: 12px;
      overflow-x: auto;
      padding: 4px 22px 16px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      margin-bottom: 4px;
    }
    .testimonials::-webkit-scrollbar { display: none; }
    .t-card {
      background: #fff;
      border-radius: var(--r-md);
      padding: 16px;
      box-shadow: var(--sh-sm);
      border: 1px solid var(--border-card);
      min-width: 260px;
      max-width: 260px;
      scroll-snap-align: start;
      flex-shrink: 0;
    }
    .t-top {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .t-avatar {
      width: 38px; height: 38px;
      border-radius: 50%;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 800;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .t-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--bg-dark);
    }
    .t-role { font-size: 11px; color: var(--text-sub); margin-top: 1px; }
    .t-stars { font-size: 11px; color: var(--warning); margin-left: auto; }
    .t-text { font-size: 13px; color: #4A4870; line-height: 1.58; }
    .t-outcome {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 9px;
      font-size: 11px;
      font-weight: 700;
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--success);
      background: #F0FDF4;
      border-radius: var(--r-sm);
      padding: 4px 9px;
    }

    /* ── Logos marquee ── */
    .logos-section { margin-bottom: 28px; }
    .logos-label {
      font-size: 10.5px;
      font-weight: 700;
      font-family: 'Plus Jakarta Sans', sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin-bottom: 14px;
      padding: 0 22px;
    }
    .logos-marquee-wrap {
      overflow: hidden;
      width: 100%;
      /* fade edges */
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    }
    .logos-marquee {
      display: flex;
      align-items: center;
      gap: 10px;
      width: max-content;
      animation: marqueeScroll 22s linear infinite;
    }
    .logos-marquee:hover { animation-play-state: paused; }
    @keyframes marqueeScroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .logo-chip {
      background: #fff;
      border: 1px solid var(--neutral-300);
      border-radius: var(--radius-lg);
      padding: 7px 14px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 12.5px;
      font-weight: 700;
      color: var(--primary-1000);
      white-space: nowrap;
      box-shadow: var(--shadow-sm);
      flex-shrink: 0;
    }

    /* ── Anchor scroll link (fold 1 bottom) ── */
    .anchor-scroll-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      width: 100%;
      padding: 13px 20px;
      background: transparent;
      color: var(--brand-primary);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      border: 1.5px solid rgba(74,71,255,0.25);
      border-radius: var(--r-xl);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
      letter-spacing: -0.01em;
    }
    .anchor-scroll-btn:hover {
      background: rgba(74,71,255,0.05);
      border-color: rgba(74,71,255,0.45);
    }
    .anchor-scroll-btn:active { transform: scale(0.98); }

    /* ── Minimal footer ── */
    .land-footer {
      background: #fff;
      border-top: 1px solid var(--neutral-300);
      padding: 18px 22px 24px;
      text-align: center;
    }
    .land-footer-links {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      margin-bottom: 8px;
    }
    .land-footer-link {
      font-size: 11px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 600;
      color: var(--neutral-700);
      cursor: pointer;
      text-decoration: none;
      transition: color 0.12s;
    }
    .land-footer-link:hover { color: var(--primary-1000); }
    .land-footer-sep {
      font-size: 11px;
      color: var(--neutral-400);
    }
    .land-footer-copy {
      font-size: 11px;
      color: var(--neutral-500);
      margin-bottom: 6px;
    }
    .land-footer-disclaimer {
      font-size: 10px;
      color: var(--neutral-400);
      font-style: italic;
      line-height: 1.55;
      padding: 0 8px;
    }

    /* Fold 2 bottom CTA */
    .proof-fold-cta {
      padding: 0 22px;
    }
    .proof-fold-cta button {
      width: 100%;
      padding: 16px;
      background: var(--brand-secondary);
      color: #fff;
      border: none;
      border-radius: var(--r-xl);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(251,116,58,0.40);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      letter-spacing: -0.01em;
    }

    /* ============================================================
       SCREEN 2 — CHAT ARENA
    ============================================================ */
    #screen-chat {
      background: var(--bg-page);
    }

    /* Chat top bar */
    .chat-bar {
      background: var(--bg-dark);
      padding: 14px 16px 12px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
      box-shadow: 0 2px 16px rgba(0,0,0,0.4);
      z-index: 10;
    }
    .chat-bar-back {
      width: 32px; height: 32px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 18px;
      color: var(--text-on-dark-sub);
      flex-shrink: 0;
    }
    .asha-orb {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: linear-gradient(140deg, #6B69FF 0%, var(--primary) 100%);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 17px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
      position: relative;
      box-shadow: 0 0 0 3px rgba(74,71,255,0.3);
    }
    .asha-orb::after {
      content: '';
      position: absolute;
      bottom: 1px; right: 1px;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--success);
      border: 2px solid var(--bg-dark);
    }
    .chat-bar-info { flex: 1; }
    .chat-bar-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14.5px;
      font-weight: 700;
      color: #fff;
      line-height: 1;
    }
    .chat-bar-status {
      font-size: 11px;
      color: var(--success);
      margin-top: 3px;
    }
    .chat-bar-menu {
      font-size: 22px;
      color: var(--text-on-dark-sub);
      cursor: pointer;
      padding: 0 4px;
    }

    /* Message area */
    .chat-feed {
      flex: 1;
      overflow-y: auto;
      padding: 16px 15px 12px;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
    .chat-feed::-webkit-scrollbar { display: none; }

    .date-sep {
      text-align: center;
      font-size: 11px;
      color: var(--text-muted);
      padding: 6px 0 8px;
      font-weight: 500;
    }

    /* Message rows */
    .mrow {
      display: flex;
      align-items: flex-end;
      gap: 7px;
      animation: popIn 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes popIn {
      from { opacity: 0; transform: translateY(12px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .mrow.bot { justify-content: flex-start; }
    .mrow.user { justify-content: flex-end; }

    .mrow-avatar {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: linear-gradient(140deg, #6B69FF, var(--primary));
      display: flex; align-items: center; justify-content: center;
      font-size: 11px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
    }

    .bubble {
      max-width: 82%;
      padding: 10px 14px;
      font-size: 14px;
      line-height: 1.55;
      border-radius: 18px;
    }
    .bubble b { font-weight: 700; }
    .bubble em { font-style: italic; }
    .bubble.bot {
      background: var(--chat-bot-bg);
      color: var(--text-body);
      border-bottom-left-radius: 4px;
      box-shadow: 0 1px 5px rgba(0,0,0,0.09);
    }
    .bubble.user {
      background: var(--chat-user-bg);
      color: #fff;
      border-bottom-right-radius: 4px;
      box-shadow: 0 2px 8px rgba(74,71,255,0.3);
    }

    /* Typing indicator */
    .typing-row {
      display: flex;
      align-items: flex-end;
      gap: 7px;
      animation: popIn 0.28s ease;
    }
    .typing-bubble {
      background: var(--chat-bot-bg);
      border-radius: 18px;
      border-bottom-left-radius: 4px;
      padding: 12px 16px;
      display: flex;
      gap: 5px;
      box-shadow: 0 1px 5px rgba(0,0,0,0.09);
    }
    .t-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--text-muted);
      animation: tdot 1.3s ease-in-out infinite;
    }
    .t-dot:nth-child(2) { animation-delay: 0.16s; }
    .t-dot:nth-child(3) { animation-delay: 0.32s; }
    @keyframes tdot {
      0%, 55%, 100% { transform: translateY(0); opacity: 0.5; }
      27%  { transform: translateY(-5px); opacity: 1; }
    }

    /* ── Full-width stacked option cards (replaces pill chips) ── */
    .opt-row {
      display: flex;
      flex-direction: column;
      gap: 7px;
      padding: 6px 16px 4px 52px;
      animation: popIn 0.28s ease 0.08s backwards;
    }
    .opt-card {
      width: 100%;
      padding: 12px 14px;
      background: var(--white);
      border: 1.5px solid var(--border-light);
      border-radius: var(--r-md);
      font-size: 13.5px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 600;
      color: var(--primary);
      cursor: pointer;
      text-align: left;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: var(--shadow-sm);
      transition: background 0.12s, color 0.12s, border-color 0.12s, transform 0.1s;
    }
    .opt-card:hover { border-color: var(--primary); background: rgba(74,71,255,0.03); }
    .opt-card:active { transform: scale(0.985); }
    .opt-card.sel { background: var(--primary); color: #fff; border-color: var(--primary); }
    .opt-chevron { font-size: 16px; color: var(--neutral-400); flex-shrink: 0; font-weight: 400; }
    .opt-card.sel .opt-chevron { color: rgba(255,255,255,0.6); }

    /* ── Profile analysis card ── */
    .profile-card {
      max-width: 90%;
      background: var(--white);
      border-radius: var(--r-lg);
      border: 1px solid var(--border-card);
      box-shadow: var(--shadow-md);
      overflow: hidden;
    }
    .profile-card-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      cursor: pointer;
      user-select: none;
      background: linear-gradient(135deg, #F4F3FF 0%, #fff 100%);
      border-bottom: 1px solid var(--border-card);
    }
    .profile-card-icon { font-size: 18px; flex-shrink: 0; }
    .profile-card-text { flex: 1; }
    .profile-card-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--primary-1000);
    }
    .profile-card-subtitle { font-size: 11px; color: var(--neutral-700); margin-top: 2px; }
    .profile-card-toggle {
      font-size: 18px; color: var(--neutral-500);
      transition: transform 0.22s ease; line-height: 1; flex-shrink: 0;
    }
    .profile-card-toggle.open { transform: rotate(180deg); }
    .profile-card-body { padding: 0 0 4px; display: none; }
    .profile-card-body.open { display: block; }
    .profile-row {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 16px; border-bottom: 1px solid var(--border-card);
    }
    .profile-row:hover { background: var(--neutral-100); }
    .profile-field-icon { font-size: 14px; flex-shrink: 0; width: 20px; }
    .profile-field-label {
      font-size: 10.5px; font-weight: 700; color: var(--neutral-500);
      text-transform: uppercase; letter-spacing: 0.04em; flex-shrink: 0; width: 66px;
    }
    .profile-field-value {
      font-size: 12.5px; font-weight: 600; color: var(--primary-1000);
      flex: 1; font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .profile-edit-btn {
      font-size: 12px; background: none; border: none; cursor: pointer;
      padding: 4px 6px; border-radius: 6px; color: var(--neutral-400); flex-shrink: 0;
      transition: color 0.12s, background 0.12s;
    }
    .profile-edit-btn:hover { color: var(--primary); background: rgba(74,71,255,0.08); }
    .profile-edit-inp {
      flex: 1; border: 1.5px solid var(--primary); border-radius: var(--r-sm);
      padding: 4px 8px; font-size: 12.5px; font-family: 'Inter', sans-serif;
      color: var(--primary-1000); outline: none;
    }
    .profile-skills-section { padding: 10px 16px 8px; border-bottom: 1px solid var(--border-card); }
    .profile-skills-section.gap { border-bottom: none; background: #FAFAF8; }
    .profile-skills-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .profile-chips { display: flex; flex-wrap: wrap; gap: 5px; }
    .skill-chip {
      padding: 4px 10px; background: rgba(74,71,255,0.08); border-radius: var(--r-full);
      font-size: 11.5px; font-weight: 600; color: var(--primary);
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .skill-chip.gap { background: rgba(251,116,58,0.10); color: var(--brand-secondary); }
    .profile-gap-note { font-size: 10.5px; color: var(--neutral-500); margin-top: 7px; font-style: italic; }

    /* ── Resume upload — success state ── */
    .resume-card.uploaded { border-style: solid; border-color: var(--success); background: var(--success-light); }
    .resume-success-icon { font-size: 26px; margin-bottom: 6px; }
    .resume-success-name { font-family:'Plus Jakarta Sans',sans-serif; font-size:12.5px; font-weight:700; color:var(--success); margin-bottom:2px; }
    .resume-success-size { font-size:11px; color:var(--success); }

    /* Chat input bar */
    .chat-input-bar {
      background: #fff;
      border-top: 1px solid var(--border-light);
      padding: 10px 14px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .chat-field {
      flex: 1;
      padding: 10px 16px;
      background: #F5F4FF;
      border: 1.5px solid var(--border-light);
      border-radius: var(--r-full);
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      color: var(--text-body);
      outline: none;
      transition: border-color 0.15s;
    }
    .chat-field:focus { border-color: var(--primary); }
    .chat-field::placeholder { color: var(--text-muted); }

    .chat-send {
      width: 40px; height: 40px;
      background: var(--primary);
      border: none;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      flex-shrink: 0;
      box-shadow: 0 2px 10px rgba(74,71,255,0.38);
      transition: transform 0.12s;
    }
    .chat-send:active { transform: scale(0.94); }
    .chat-send svg { display: block; }

    /* Skip link under input */
    .skip-link {
      text-align: center;
      padding: 0 16px 14px;
      font-size: 12px;
      color: var(--text-muted);
      cursor: pointer;
      background: #fff;
      margin-top: -4px;
    }

    /* ---- Rich widgets (sit in chat feed) ---- */

    /* Resume upload card */
    .resume-card {
      max-width: 80%;
      background: var(--chat-bot-bg);
      border: 2px dashed #C4C3EA;
      border-radius: var(--r-md);
      padding: 20px 18px;
      text-align: center;
      cursor: pointer;
      box-shadow: var(--sh-sm);
      transition: border-color 0.15s;
    }
    .resume-card:hover { border-color: var(--primary); }
    .resume-icon { font-size: 30px; margin-bottom: 8px; }
    .resume-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-body);
      margin-bottom: 3px;
    }
    .resume-hint { font-size: 11px; color: var(--text-muted); margin-bottom: 14px; }
    .resume-actions { display: flex; gap: 8px; justify-content: center; }
    .resume-btn-upload {
      padding: 7px 18px;
      background: var(--primary);
      color: #fff;
      border-radius: var(--r-full);
      font-size: 12px;
      font-weight: 700;
      font-family: 'Plus Jakarta Sans', sans-serif;
      cursor: pointer;
      border: none;
    }
    .resume-btn-skip {
      padding: 7px 16px;
      background: transparent;
      color: var(--text-sub);
      border-radius: var(--r-full);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      border: none;
    }

    /* Visa score card */
    .visa-card {
      max-width: 85%;
      background: var(--chat-bot-bg);
      border-radius: var(--r-lg);
      padding: 18px;
      box-shadow: var(--sh-md);
      border: 1px solid var(--border-card);
      overflow: hidden;
    }
    .visa-card-label {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 10.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--text-muted);
      margin-bottom: 14px;
    }
    .visa-top {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 14px;
    }
    .arc-wrap { position: relative; width: 72px; height: 72px; flex-shrink: 0; }
    .arc-svg { width: 72px; height: 72px; transform: rotate(-90deg); }
    .arc-bg { fill: none; stroke: #EDECED; stroke-width: 8; }
    .arc-fg {
      fill: none;
      stroke: var(--primary);
      stroke-width: 8;
      stroke-linecap: round;
      stroke-dasharray: 188.4;
      stroke-dashoffset: 188.4;
      transition: stroke-dashoffset 1.2s cubic-bezier(0.22,1,0.36,1);
    }
    .arc-text {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .arc-score {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 19px;
      font-weight: 800;
      color: var(--bg-dark);
      line-height: 1;
    }
    .arc-denom { font-size: 10px; color: var(--text-muted); }
    .visa-meta { flex: 1; }
    .visa-label {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--bg-dark);
      margin-bottom: 4px;
    }
    .visa-sub { font-size: 12px; color: var(--text-sub); line-height: 1.45; }
    .visa-progress {
      display: flex;
      height: 6px;
      border-radius: var(--r-full);
      overflow: hidden;
      margin-bottom: 8px;
    }
    .vp-earned { background: var(--primary); }
    .vp-next   { background: var(--secondary); }
    .vp-later  { background: var(--border-light); flex: 1; }
    .visa-legend {
      display: flex;
      gap: 12px;
      font-size: 10px;
      color: var(--text-muted);
      margin-bottom: 14px;
    }
    .vleg-dot {
      display: inline-block;
      width: 7px; height: 7px;
      border-radius: 50%;
      margin-right: 3px;
      vertical-align: middle;
    }
    .visa-tip {
      background: #FFF3EE;
      border-left: 3px solid var(--secondary);
      border-radius: 0 var(--r-sm) var(--r-sm) 0;
      padding: 10px 12px;
      font-size: 12px;
      color: #5A3828;
      line-height: 1.5;
      margin-bottom: 14px;
    }
    .visa-tip strong { color: var(--secondary); font-weight: 700; }
    .visa-action {
      width: 100%;
      padding: 12px;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: var(--r-md);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 2px 10px rgba(74,71,255,0.28);
    }

    /* Inline job cards */
    .inline-jobs-wrap { max-width: 88%; }
    .inline-jobs-label {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 11.5px;
      font-weight: 600;
      color: var(--text-sub);
      margin-bottom: 10px;
    }
    .ijob {
      background: var(--chat-bot-bg);
      border-radius: var(--r-md);
      padding: 13px;
      margin-bottom: 8px;
      box-shadow: var(--sh-sm);
      border: 1px solid var(--border-card);
      cursor: pointer;
      transition: box-shadow 0.14s, border-color 0.14s;
    }
    .ijob:hover { box-shadow: var(--sh-md); border-color: var(--primary); }
    .ijob-top {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .ijob-logo {
      width: 36px; height: 36px;
      border-radius: var(--r-sm);
      background: var(--primary-light);
      border: 1px solid var(--border-light);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }
    .ijob-role {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--bg-dark);
      line-height: 1.3;
    }
    .ijob-co { font-size: 11px; color: var(--text-muted); }
    .tags { display: flex; gap: 6px; flex-wrap: wrap; }
    .tag {
      padding: 3px 9px;
      border-radius: var(--r-full);
      font-size: 10.5px;
      font-weight: 700;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .tag-v { background: #EEF2FF; color: #4F63E1; }
    .tag-s { background: #F0FDF4; color: #16A34A; }
    .tag-l { background: var(--primary-light); color: var(--primary); }
    .tag-o { background: var(--secondary-light); color: #C04A14; }

    .see-all-cta {
      width: 100%;
      padding: 12px;
      background: transparent;
      border: 2px solid var(--primary);
      border-radius: var(--r-md);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--primary);
      cursor: pointer;
      margin-top: 2px;
      transition: background 0.12s, color 0.12s;
    }
    .see-all-cta:hover { background: var(--primary); color: #fff; }

    /* University cards (masters path) */
    .uni-card {
      background: var(--chat-bot-bg);
      border-radius: var(--r-md);
      padding: 13px;
      margin-bottom: 8px;
      box-shadow: var(--sh-sm);
      border: 1px solid var(--border-card);
    }
    .uni-top { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 9px; }
    .uni-logo {
      width: 36px; height: 36px;
      border-radius: var(--r-sm);
      background: linear-gradient(140deg, #F0EEFF, #E4E2FF);
      border: 1px solid var(--border-light);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }
    .uni-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--bg-dark);
      line-height: 1.3;
    }
    .uni-course { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
    .uni-match {
      margin-left: auto;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 11px;
      font-weight: 800;
      color: var(--primary);
      background: var(--primary-light);
      padding: 3px 9px;
      border-radius: var(--r-full);
      white-space: nowrap;
    }

    /* ============================================================
       SCREEN 3 — JOB LISTING
    ============================================================ */
    #screen-jobs {
      background: var(--bg-page);
    }

    .jobs-topbar {
      background: var(--bg-dark);
      flex-shrink: 0;
      padding: 14px 18px 16px;
    }
    .jobs-topbar-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }
    .back-circle {
      width: 34px; height: 34px;
      background: rgba(255,255,255,0.1);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 18px;
      color: #fff;
      flex-shrink: 0;
    }
    .jobs-topbar-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: #fff;
    }
    .match-banner {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--r-md);
      padding: 13px 16px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .match-banner-icon {
      width: 46px; height: 46px;
      background: linear-gradient(140deg, var(--primary), #7B79FF);
      border-radius: var(--r-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
    }
    .match-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 24px;
      font-weight: 800;
      color: #fff;
      line-height: 1;
    }
    .match-desc { font-size: 12px; color: var(--text-on-dark-sub); margin-top: 3px; }
    .match-profile-tag {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .filter-bar {
      display: flex;
      gap: 8px;
      padding: 10px 16px;
      overflow-x: auto;
      background: #fff;
      border-bottom: 1px solid var(--border-light);
      flex-shrink: 0;
    }
    .filter-bar::-webkit-scrollbar { display: none; }
    .fchip {
      padding: 6px 14px;
      border-radius: var(--r-full);
      font-size: 12px;
      font-weight: 600;
      font-family: 'Plus Jakarta Sans', sans-serif;
      white-space: nowrap;
      cursor: pointer;
      border: 1.5px solid var(--border-light);
      background: #fff;
      color: var(--text-sub);
      transition: all 0.12s;
    }
    .fchip.on {
      background: var(--primary);
      color: #fff;
      border-color: var(--primary);
    }

    .jobs-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 12px 14px;
    }
    .jobs-scroll::-webkit-scrollbar { display: none; }

    .jcard {
      background: #fff;
      border-radius: var(--r-md);
      padding: 15px;
      margin-bottom: 10px;
      box-shadow: var(--sh-sm);
      border: 1px solid var(--border-card);
      cursor: pointer;
      transition: box-shadow 0.14s, border-color 0.14s;
    }
    .jcard:hover { box-shadow: var(--sh-md); border-color: var(--primary); }
    .jcard-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 10px;
    }
    .jcard-left { display: flex; align-items: flex-start; gap: 11px; }
    .jlogo {
      width: 44px; height: 44px;
      border-radius: var(--r-sm);
      background: var(--bg-page);
      border: 1px solid var(--border-light);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }
    .jrole {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--bg-dark);
      line-height: 1.3;
    }
    .jco { font-size: 12px; color: var(--text-sub); margin-top: 2px; }
    .mbadge {
      background: #EEF2FF;
      color: #3B5AE1;
      font-size: 11px;
      font-weight: 800;
      padding: 4px 10px;
      border-radius: var(--r-full);
      font-family: 'Plus Jakarta Sans', sans-serif;
      white-space: nowrap;
    }
    .jcard-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 10px;
    }
    .jsalary {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: #16A34A;
    }
    .jposted { font-size: 11px; color: var(--text-muted); }

    .jobs-cta-bar {
      background: #fff;
      border-top: 1px solid var(--border-light);
      padding: 14px 16px 26px;
      flex-shrink: 0;
    }
    .jobs-cta-btn {
      width: 100%;
      padding: 16px;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: var(--r-md);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: var(--sh-primary);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    /* ============================================================
       BOOKING MODAL (bottom sheet)
    ============================================================ */
    #modal-booking {
      position: fixed;
      inset: 0;
      z-index: 200;
      background: rgba(16,15,51,0.75);
      backdrop-filter: blur(6px);
      display: none;
      align-items: flex-end;
      justify-content: center;
    }
    #modal-booking.open { display: flex; }

    .booking-sheet {
      width: 390px;
      background: #fff;
      border-radius: 22px 22px 0 0;
      max-height: 92vh;
      overflow-y: auto;
      animation: sheetUp 0.36s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .booking-sheet::-webkit-scrollbar { display: none; }
    @keyframes sheetUp {
      from { transform: translateY(100%); }
      to   { transform: translateY(0); }
    }

    .sheet-handle {
      width: 38px; height: 4px;
      background: var(--border-light);
      border-radius: 2px;
      margin: 12px auto 0;
    }
    .sheet-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 20px 0;
    }
    .sheet-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 18px;
      font-weight: 800;
      color: var(--bg-dark);
    }
    .sheet-close {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--bg-page);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 16px;
      color: var(--text-sub);
      border: none;
    }
    .sheet-body { padding: 18px 20px 28px; }

    .mentor-row {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-page);
      border-radius: var(--r-md);
      padding: 13px;
      margin-bottom: 20px;
    }
    .mentor-orb {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: linear-gradient(140deg, #6B69FF, var(--primary));
      display: flex; align-items: center; justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 18px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
    }
    .mentor-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--bg-dark);
    }
    .mentor-title { font-size: 12px; color: var(--text-sub); margin-top: 2px; }
    .mentor-stars { font-size: 11px; color: var(--warning); margin-top: 3px; }

    .form-lbl {
      display: block;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-sub);
      margin-bottom: 6px;
    }
    .form-grp { margin-bottom: 15px; }
    .form-inp {
      width: 100%;
      padding: 11px 14px;
      background: var(--bg-page);
      border: 1.5px solid var(--border-light);
      border-radius: var(--r-md);
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      color: var(--text-body);
      outline: none;
      transition: border-color 0.15s;
    }
    .form-inp:focus { border-color: var(--primary); background: #fff; }
    .form-inp.pre { color: var(--text-sub); }

    .sect-lbl {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-sub);
      margin-bottom: 10px;
    }

    .date-strip {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      margin-bottom: 18px;
      padding-bottom: 2px;
    }
    .date-strip::-webkit-scrollbar { display: none; }
    .dchip {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 10px 13px;
      border: 1.5px solid var(--border-light);
      border-radius: var(--r-md);
      cursor: pointer;
      min-width: 58px;
      transition: all 0.12s;
    }
    .dchip.on { border-color: var(--primary); background: var(--primary); }
    .dday { font-size: 10px; font-weight: 600; font-family: 'Plus Jakarta Sans', sans-serif; color: var(--text-muted); }
    .dchip.on .dday { color: rgba(255,255,255,0.7); }
    .ddate { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 17px; font-weight: 800; color: var(--bg-dark); margin: 2px 0; }
    .dchip.on .ddate { color: #fff; }
    .dmonth { font-size: 9px; color: var(--text-muted); }
    .dchip.on .dmonth { color: rgba(255,255,255,0.7); }

    .time-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 20px;
    }
    .tslot {
      padding: 11px 6px;
      border: 1.5px solid var(--border-light);
      border-radius: var(--r-md);
      text-align: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-sub);
      cursor: pointer;
      transition: all 0.12s;
    }
    .tslot.on { border-color: var(--primary); background: var(--primary); color: #fff; }
    .tslot.off {
      color: #CECCE8;
      background: var(--bg-page);
      cursor: not-allowed;
      text-decoration: line-through;
    }

    .confirm-btn {
      width: 100%;
      padding: 16px;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: var(--r-md);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: var(--sh-primary);
      transition: transform 0.12s;
    }
    .confirm-btn:active { transform: scale(0.98); }

    /* Success view */
    #booking-success {
      padding: 36px 20px 40px;
      text-align: center;
      display: none;
    }
    .success-orb {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: linear-gradient(140deg, #22C55E, #16A34A);
      display: flex; align-items: center; justify-content: center;
      font-size: 30px;
      margin: 0 auto 20px;
      animation: pop 0.45s cubic-bezier(0.22,1,0.36,1);
    }
    @keyframes pop {
      from { transform: scale(0); opacity: 0; }
      to   { transform: scale(1); opacity: 1; }
    }
    .success-h { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 22px; font-weight: 800; color: var(--bg-dark); margin-bottom: 10px; }
    .success-sub { font-size: 14px; color: var(--text-sub); line-height: 1.6; margin-bottom: 22px; }
    .success-detail {
      background: var(--bg-page);
      border-radius: var(--r-md);
      padding: 16px;
      text-align: left;
      margin-bottom: 18px;
    }
    .sd-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      color: var(--text-sub);
      padding: 5px 0;
      border-bottom: 1px solid var(--border-light);
    }
    .sd-row:last-child { border-bottom: none; }
    .sd-row strong { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; color: var(--bg-dark); }
    .wa-btn {
      width: 100%;
      padding: 14px;
      background: #25D366;
      color: #fff;
      border: none;
      border-radius: var(--r-md);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    /* ============================================================
       SCREEN 4 — VISA ROADMAP
    ============================================================ */
    #screen-roadmap { background: var(--bg-page); }
    .roadmap-topbar {
      background: var(--white);
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--border-light);
      flex-shrink: 0;
      box-shadow: var(--shadow-sm);
    }
    .roadmap-topbar-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      color: var(--primary-1000);
      flex: 1;
    }
    .roadmap-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .roadmap-scroll::-webkit-scrollbar { display: none; }

    /* Score header card */
    .roadmap-score-card {
      background: var(--white);
      border-radius: var(--r-lg);
      padding: 18px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-card);
    }
    .roadmap-visa-type {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--neutral-500);
      margin-bottom: 10px;
    }
    .roadmap-score-row {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 10px;
    }
    .roadmap-score-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 42px;
      font-weight: 800;
      color: var(--primary-1000);
      line-height: 1;
    }
    .roadmap-score-denom {
      font-size: 16px;
      color: var(--neutral-500);
      font-weight: 600;
    }
    .roadmap-score-label {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--primary-1000);
    }
    .roadmap-score-sub { font-size: 12px; color: var(--neutral-700); margin-top: 2px; }
    .roadmap-bar-wrap {
      background: var(--neutral-200);
      border-radius: var(--r-full);
      height: 8px;
      overflow: hidden;
      margin-top: 12px;
    }
    .roadmap-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--primary) 0%, #7B79FF 100%);
      border-radius: var(--r-full);
      transition: width 1.2s cubic-bezier(0.22,1,0.36,1);
    }
    .roadmap-bar-legend {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      color: var(--neutral-500);
      margin-top: 5px;
    }

    /* Section heading */
    .roadmap-section-head {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 800;
      color: var(--primary-1000);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 4px 0 2px;
    }

    /* Pathway cards */
    .pathway-card {
      background: var(--white);
      border-radius: var(--r-lg);
      padding: 16px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-card);
      border-left: 4px solid var(--primary);
    }
    .pathway-card.likely { border-left-color: var(--success); }
    .pathway-card.young  { border-left-color: var(--warning); }
    .pathway-card.masters{ border-left-color: var(--info); }
    .pathway-badge {
      display: inline-flex;
      align-items: center;
      font-size: 9.5px;
      font-weight: 800;
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: 0.08em;
      padding: 3px 8px;
      border-radius: var(--r-full);
      margin-bottom: 8px;
    }
    .pathway-card.likely .pathway-badge { background: var(--success-light); color: var(--success); }
    .pathway-card.young  .pathway-badge { background: var(--warning-light); color: var(--warning); }
    .pathway-card.masters .pathway-badge { background: var(--info-light); color: var(--info); }
    .pathway-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--primary-1000);
      margin-bottom: 6px;
    }
    .pathway-desc { font-size: 12.5px; color: var(--neutral-700); line-height: 1.55; }
    .pathway-pts {
      display: inline-block;
      margin-top: 10px;
      background: rgba(74,71,255,0.08);
      color: var(--primary);
      font-size: 11.5px;
      font-weight: 700;
      font-family: 'Plus Jakarta Sans', sans-serif;
      padding: 3px 10px;
      border-radius: var(--r-full);
    }

    /* Points breakdown table */
    .points-table {
      background: var(--white);
      border-radius: var(--r-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-card);
    }
    .pts-row {
      display: flex;
      align-items: center;
      padding: 11px 16px;
      border-bottom: 1px solid var(--border-card);
      gap: 10px;
    }
    .pts-row:last-child { border-bottom: none; }
    .pts-row-icon { font-size: 16px; flex-shrink: 0; }
    .pts-row-label { flex: 1; font-size: 12.5px; font-weight: 500; color: var(--text-body); }
    .pts-row-val {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 800;
      color: var(--primary);
      flex-shrink: 0;
    }
    .pts-row-val.missing { color: var(--neutral-400); }
    .pts-row-val.earned { color: var(--success); }

    /* Roadmap CTA zone */
    .roadmap-cta-zone {
      background: var(--white);
      border-radius: var(--r-lg);
      padding: 20px 16px;
      text-align: center;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-card);
    }
    .roadmap-cta-heading {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      color: var(--primary-1000);
      margin-bottom: 6px;
    }
    .roadmap-cta-sub-text { font-size: 12.5px; color: var(--neutral-700); margin-bottom: 16px; }
    .roadmap-cta-btn {
      width: 100%;
      padding: 15px;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: var(--r-xl);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: var(--sh-primary);
    }
    .roadmap-cta-note { font-size: 11px; color: var(--neutral-500); margin-top: 10px; }

    /* ============================================================
       SCREEN 5 — JOB DETAIL
    ============================================================ */
    #screen-job-detail { background: var(--bg-page); }
    .jd-topbar {
      background: var(--white);
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--border-light);
      flex-shrink: 0;
      box-shadow: var(--shadow-sm);
    }
    .jd-topbar-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--primary-1000);
      flex: 1;
    }
    .jd-topbar-dots { font-size: 20px; color: var(--neutral-500); cursor: pointer; }
    .jd-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 0 0 90px;
    }
    .jd-scroll::-webkit-scrollbar { display: none; }

    /* Header card */
    .jd-header-card {
      background: var(--white);
      padding: 18px 16px 16px;
      border-bottom: 1px solid var(--border-light);
    }
    .jd-company-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }
    .jd-company-logo {
      width: 42px; height: 42px;
      background: var(--primary);
      border-radius: var(--r-md);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
    }
    .jd-company-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--primary-1000);
    }
    .jd-location { font-size: 11.5px; color: var(--neutral-700); margin-top: 2px; }
    .jd-sponsor-badge {
      margin-left: auto;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: var(--success-light);
      color: var(--success);
      font-size: 10.5px;
      font-weight: 700;
      font-family: 'Plus Jakarta Sans', sans-serif;
      padding: 4px 10px;
      border-radius: var(--r-full);
      flex-shrink: 0;
    }
    .jd-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 20px;
      font-weight: 800;
      color: var(--primary-1000);
      letter-spacing: -0.02em;
      margin-bottom: 8px;
      line-height: 1.2;
    }
    .jd-salary {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: var(--success);
      margin-bottom: 10px;
    }
    .jd-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .jd-tag {
      padding: 4px 11px;
      background: var(--neutral-200);
      border-radius: var(--r-full);
      font-size: 11.5px;
      font-weight: 600;
      color: var(--neutral-700);
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* Match card */
    .jd-match-card {
      background: linear-gradient(135deg, #F4F3FF 0%, #EDF4FF 100%);
      border: 1px solid rgba(74,71,255,0.18);
      margin: 12px 12px 0;
      border-radius: var(--r-md);
      padding: 14px;
    }
    .jd-match-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
    .jd-match-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 12px;
      font-weight: 700;
      color: var(--primary);
    }
    .jd-match-pct {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 800;
      color: var(--primary);
    }
    .jd-match-body { font-size: 12px; color: var(--neutral-700); line-height: 1.55; }

    /* JD sections */
    .jd-section { padding: 16px; border-bottom: 1px solid var(--border-light); background: var(--white); margin-top: 10px; }
    .jd-section-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--primary-1000);
      margin-bottom: 10px;
    }
    .jd-section-body { font-size: 13px; color: var(--neutral-700); line-height: 1.65; }
    .jd-bullets { padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 7px; }
    .jd-bullets li {
      font-size: 13px;
      color: var(--neutral-700);
      line-height: 1.55;
      padding-left: 16px;
      position: relative;
    }
    .jd-bullets li::before { content: '•'; position: absolute; left: 0; color: var(--primary); font-weight: 700; }

    /* Sticky bottom bar */
    .jd-bottom-bar {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      background: var(--white);
      border-top: 1px solid var(--border-light);
      padding: 12px 16px;
      display: flex;
      gap: 10px;
      box-shadow: 0 -4px 20px rgba(28,34,51,0.10);
    }
    .jd-btn-mentor {
      flex: 1;
      padding: 14px 12px;
      background: transparent;
      color: var(--primary);
      border: 1.5px solid var(--primary);
      border-radius: var(--r-md);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.12s;
    }
    .jd-btn-mentor:hover { background: rgba(74,71,255,0.06); }
    .jd-btn-apply {
      flex: 1.4;
      padding: 14px 12px;
      background: var(--brand-secondary);
      color: #fff;
      border: none;
      border-radius: var(--r-md);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(251,116,58,0.38);
      letter-spacing: -0.01em;
    }

    /* ============================================================
       SCREEN 4 — ROADMAP (new layout classes)
    ============================================================ */

    /* Score card */
    .score-card {
      background: var(--white);
      border-radius: var(--r-lg);
      padding: 18px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-card);
    }
    .score-card-label {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--neutral-500);
      margin-bottom: 10px;
    }
    .score-bar-wrap { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
    .score-bar-track {
      flex: 1;
      height: 9px;
      background: var(--neutral-200);
      border-radius: var(--r-full);
      overflow: hidden;
    }
    .score-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--primary) 0%, #7B79FF 100%);
      border-radius: var(--r-full);
      transition: width 1.2s cubic-bezier(0.22,1,0.36,1);
    }
    .score-bar-pct {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 800;
      color: var(--primary);
      flex-shrink: 0;
    }
    .score-card-sub {
      font-size: 12px;
      color: var(--neutral-700);
      line-height: 1.55;
      margin-bottom: 14px;
    }
    .score-pillars { display: flex; flex-direction: column; gap: 9px; }
    .pillar { display: flex; align-items: center; gap: 9px; }
    .pillar-label {
      font-size: 11.5px;
      font-weight: 600;
      color: var(--neutral-700);
      width: 68px;
      flex-shrink: 0;
    }
    .pillar-bar {
      flex: 1;
      height: 6px;
      background: var(--neutral-200);
      border-radius: var(--r-full);
      overflow: hidden;
    }
    .pillar-fill {
      height: 100%;
