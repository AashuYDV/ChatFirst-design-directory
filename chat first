function renderDates() {
  const strip = document.getElementById('date-strip');
  strip.innerHTML = '';
  const data = [
    { day:'Mon', d:3, m:'Mar' },
    { day:'Tue', d:4, m:'Mar' },
    { day:'Wed', d:5, m:'Mar' },
    { day:'Thu', d:6, m:'Mar' },
    { day:'Fri', d:7, m:'Mar' },
  ];
  data.forEach((item, i) => {
    const el = document.createElement('div');
    el.className = 'dchip' + (i === 0 ? ' on' : '');
    el.innerHTML = `<div class="dday">${item.day}</div><div class="ddate">${item.d}</div><div class="dmonth">${item.m}</div>`;
    el.onclick = () => {
      document.querySelectorAll('.dchip').forEach(c => c.classList.remove('on'));
      el.classList.add('on');
      _selDate = `${item.day}, ${item.m} ${item.d}`;
    };
    strip.appendChild(el);
  });
  _selDate = 'Mon, Mar 3';
}

function pickSlot(el) {
  document.querySelectorAll('.tslot').forEach(s => s.classList.remove('on'));
  el.classList.add('on');
  _selTime = el.textContent;
}

function confirmBooking() {
  if (!_selTime) {
    const first = document.querySelector('.tslot:not(.off)');
    if (first) { first.classList.add('on'); _selTime = first.textContent; }
  }
  document.getElementById('s-mentor').textContent = document.getElementById('mentor-name').textContent;
  document.getElementById('s-date').textContent   = _selDate || 'Mon, Mar 3';
  document.getElementById('s-time').textContent   = (_selTime || '9:00 AM') + ' IST';
  document.getElementById('booking-form-view').style.display = 'none';
  document.getElementById('booking-success').style.display   = 'block';
}

