<!-- ═══════════════════════════════════════════
     JAVASCRIPT ENGINE
═══════════════════════════════════════════ -->
<script>
'use strict';

/* ──────────────────────────────────────────
   SCREEN ROUTER
────────────────────────────────────────── */
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const map = { landing: 'screen-landing', chat: 'screen-chat', jobs: 'screen-jobs', roadmap: 'screen-roadmap', jobdetail: 'screen-job-detail' };
  document.getElementById(map[name]).classList.add('active');
}

function scrollToFold2() {
  /* Scroll happens inside #screen-landing (overflow-y:auto), not window */
  const target = document.getElementById('fold2');
  const container = document.getElementById('screen-landing');
  if (target && container) {
    container.scrollTo({ top: target.offsetTop, behavior: 'smooth' });
  }
}

function startChat() {
  showScreen('chat');
  // Reset chat state
  window._answers = {};
  _queue = [];
  _busy  = false;
  const feed = document.getElementById('chat-feed');
  feed.innerHTML = '<div class="date-sep">Today</div>';
  document.getElementById('chat-input-zone').innerHTML = '';
  initFlow();
}

/* ──────────────────────────────────────────
   CHAT ENGINE
────────────────────────────────────────── */
const feed = () => document.getElementById('chat-feed');
const zone = () => document.getElementById('chat-input-zone');

let _queue = [];
let _busy  = false;

function enqueue(items) {
  _queue.push(...items);
  if (!_busy) drain();
}

function drain() {
  if (!_queue.length) { _busy = false; return; }
  _busy = true;
  const item = _queue.shift();

  if (item.type === 'wait') {
    setTimeout(drain, item.ms);

  } else if (item.type === 'typing') {
    showTyping();
    setTimeout(() => { killTyping(); drain(); }, item.ms || 1100);

  } else if (item.type === 'bot') {
    killTyping();
    addBubble('bot', item.html || item.text);
    setTimeout(drain, 200);

  } else if (item.type === 'chips') {
    renderChips(item.opts, item.cb);
    _busy = false;

  } else if (item.type === 'textinput') {
    renderTextInput(item.ph, item.cb, item.skippable);
    _busy = false;

  } else if (item.type === 'upload') {
    renderUpload(item.onUp, item.onSkip);
    _busy = false;

  } else if (item.type === 'widget') {
    killTyping();
    const row = document.createElement('div');
    row.className = 'mrow bot';
    row.innerHTML = `<div class="mrow-avatar">A</div>${item.html}`;
    feed().appendChild(row);
    scroll();
    setTimeout(drain, 300);

  } else if (item.type === 'fn') {
    item.cb();
    setTimeout(drain, 100);
  }
}

function addBubble(who, html) {
  const row = document.createElement('div');
  row.className = `mrow ${who}`;
  if (who === 'bot') {
    row.innerHTML = `<div class="mrow-avatar">A</div><div class="bubble bot">${html}</div>`;
  } else {
    row.innerHTML = `<div class="bubble user">${html}</div>`;
  }
  feed().appendChild(row);
  scroll();
}

function showTyping() {
  killTyping();
  const row = document.createElement('div');
  row.id = 'typing-row';
  row.className = 'typing-row';
  row.innerHTML = `
    <div class="mrow-avatar">A</div>
    <div class="typing-bubble">
      <div class="t-dot"></div><div class="t-dot"></div><div class="t-dot"></div>
    </div>`;
  feed().appendChild(row);
  scroll();
}

function killTyping() {
  const t = document.getElementById('typing-row');
  if (t) t.remove();
}

function renderChips(opts, cb) {
  clearZone();
  killTyping();
  const row = document.createElement('div');
  row.className = 'opt-row';
  row.id = 'chip-row-live';
  opts.forEach(o => {
    const btn = document.createElement('button');
    btn.className = 'opt-card';
    btn.innerHTML = `<span>${o}</span><span class="opt-chevron">›</span>`;
    btn.onclick = () => {
      btn.classList.add('sel');
      setTimeout(() => {
        addBubble('user', o);
        document.getElementById('chip-row-live')?.remove();
        clearZone();
        cb(o);
        drain();
      }, 160);
    };
    row.appendChild(btn);
  });
  feed().appendChild(row);
  scroll();
}

function renderTextInput(ph, cb, skippable) {
  zone().innerHTML = `
    <div class="chat-input-bar">
      <input class="chat-field" id="chat-field" type="text" placeholder="${ph}" autocomplete="off">
      <button class="chat-send" onclick="_sendText()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
    ${skippable ? '<div class="skip-link" onclick="_skipText()">Skip for now →</div>' : ''}
  `;
  document.getElementById('chat-field').addEventListener('keypress', e => { if (e.key === 'Enter') _sendText(); });
  document.getElementById('chat-field').focus();
  window.__textCb = cb;
}

window._sendText = function() {
  const f = document.getElementById('chat-field');
  const v = f?.value?.trim();
  if (!v) return;
  addBubble('user', v);
  clearZone();
  if (window.__textCb) { window.__textCb(v); drain(); }
};
window._skipText = function() {
  addBubble('user', 'Skip for now');
  clearZone();
  if (window.__textCb) { window.__textCb('__skip__'); drain(); }
};

function renderUpload(onUp, onSkip) {
  clearZone();
  const row = document.createElement('div');
  row.className = 'mrow bot';
  row.id = 'upload-row';
  row.innerHTML = `
    <div class="mrow-avatar">A</div>
    <div class="resume-card" id="resume-card-inner">
      <div class="resume-icon">📄</div>
      <div class="resume-title">Upload your resume</div>
      <div class="resume-hint">PDF, DOC or DOCX · Max 5MB</div>
      <div class="resume-actions">
        <label class="resume-btn-upload" for="resume-file-inp" style="cursor:pointer;">
          📎 Choose File
        </label>
        <input type="file" id="resume-file-inp" accept=".pdf,.doc,.docx"
               style="display:none" onchange="_handleFileSelect(this)">
        <button class="resume-btn-skip" onclick="_doSkip()">Skip →</button>
      </div>
    </div>`;
  feed().appendChild(row);
  scroll();
  window.__upCb   = onUp;
  window.__skipCb = onSkip;
}

window._handleFileSelect = function(input) {
  const file = input.files[0];
  if (!file) return;
  window.__lastFile = file;
  const card = document.getElementById('resume-card-inner');
  card.classList.add('uploaded');
  card.innerHTML = `
    <div class="resume-success-icon">✅</div>
    <div class="resume-success-name">${file.name}</div>
    <div class="resume-success-size">${(file.size / 1024).toFixed(0)} KB · Uploaded successfully</div>`;
  setTimeout(() => {
    addBubble('user', `📄 ${file.name}`);
    document.getElementById('upload-row')?.remove();
    clearZone();
    if (window.__upCb) { window.__upCb(file); drain(); }
  }, 1100);
};

window._doSkip = function() {
  addBubble('user', 'Skip for now');
  document.getElementById('upload-row')?.remove();
  clearZone();
  if (window.__skipCb) { window.__skipCb(null); drain(); }
};

function clearZone() { zone().innerHTML = ''; }
function scroll() { setTimeout(() => { const f = feed(); f.scrollTop = f.scrollHeight; }, 60); }

/* ──────────────────────────────────────────
   CHAT FLOWS
────────────────────────────────────────── */
function initFlow() {
  enqueue([
    { type: 'wait', ms: 350 },
    { type: 'typing', ms: 950 },
    { type: 'bot', html: "Hey there! 👋 I'm <b>Asha</b>, your Leap career guide.<br><br>I'll ask you a few quick questions and match you with the best opportunities abroad. Ready? 🚀" },
    { type: 'wait', ms: 400 },
    { type: 'typing', ms: 800 },
    { type: 'bot', text: 'First, which country interests you most?' },
    {
      type: 'chips',
      opts: ['🇬🇧 United Kingdom', '🇮🇪 Ireland', '🇦🇺 Australia', '🌍 Other'],
      cb: c => {
        window._answers = window._answers || {};
        window._answers.country = c;
        if (c === '🌍 Other') flowOtherCountry();
        else flowExperience();
      }
    }
  ]);
}

function flowOtherCountry() {
  enqueue([
    { type: 'wait', ms: 250 },
    { type: 'typing', ms: 900 },
    { type: 'bot', html: "We're launching more countries soon! 🌍 I've added you to the waitlist for your region.<br><br>Want to explore <b>UK &amp; Ireland</b> opportunities today while we work on it?" },
    {
      type: 'chips',
      opts: ['Yes, show me UK options', "I'll wait for my country"],
      cb: c => {
        if (c.startsWith('Yes')) {
          window._answers.country = '🇬🇧 United Kingdom';
          flowExperience();
        } else {
          enqueue([
            { type: 'typing', ms: 750 },
            { type: 'bot', html: "Got it! I'll personally notify you when we launch your country. You're on the list 💌" }
          ]);
        }
      }
    }
  ]);
}

function flowExperience() {
  enqueue([
    { type: 'wait', ms: 300 },
    { type: 'typing', ms: 800 },
    { type: 'bot', text: 'And how many years of work experience do you have?' },
    {
      type: 'chips',
      opts: ['0–2 years', '3–5 years', '6–10 years', '10+ years'],
      cb: c => {
        window._answers.exp = c;
        flowPathFork();
      }
    }
  ]);
}

function flowPathFork() {
  enqueue([
    { type: 'wait', ms: 300 },
    { type: 'typing', ms: 950 },
    { type: 'bot', html: "Perfect! Now tell me, what brings you here today? I'll personalise everything for you 🎯" },
    {
      type: 'chips',
      opts: ['💼 Get a job abroad', '🎓 Pursue a Masters', '🤔 Help me decide'],
      cb: c => {
        window._answers.goal = c;
        if (c.includes('job'))    flowJobs();
        else if (c.includes('Masters')) flowMasters();
        else flowDecide();
      }
    }
  ]);
}

function flowDecide() {
  enqueue([
    { type: 'wait', ms: 250 },
    { type: 'typing', ms: 1100 },
    { type: 'bot', html: "Let me help you decide 🧭<br><br>If you have <b>3+ years of work experience</b>, the <b>Skilled Worker route</b> can get you to the UK in 3–4 months with a job offer.<br><br>If you want to <b>upskill first</b>, a <b>Masters</b> gives you 2 years on a student visa plus a Graduate visa to work right after." },
    { type: 'wait', ms: 200 },
    { type: 'typing', ms: 700 },
    { type: 'bot', text: "Which feels more like you?" },
    {
      type: 'chips',
      opts: ['💼 Jobs route for me', '🎓 Masters route for me'],
      cb: c => { if (c.includes('Jobs')) flowJobs(); else flowMasters(); }
    }
  ]);
}

/* ── JOBS PATH ── */
function flowJobs() {
  enqueue([
    { type: 'wait', ms: 250 },
    { type: 'typing', ms: 800 },
    { type: 'bot', html: "Love it! Let's find your perfect role. 💼<br><br>What's your current job title?" },
    {
      type: 'textinput',
      ph: 'e.g. Software Engineer, Data Analyst…',
      cb: v => { window._answers.title = v; flowJobsDomain(); }
    }
  ]);
}

function flowJobsDomain() {
  enqueue([
    { type: 'typing', ms: 900 },
    { type: 'bot', html: "And which domain are you <em>targeting</em>? (Can be different from your current role)" },
    {
      type: 'chips',
      opts: ['💻 Technology', '📊 Finance & Banking', '🏥 Healthcare', '📈 Data & Analytics', '⚙️ Engineering', '🎨 Design & Creative'],
      cb: v => { window._answers.domain = v; flowJobsCTC(); }
    }
  ]);
}

function flowJobsCTC() {
  enqueue([
    { type: 'typing', ms: 850 },
    { type: 'bot', html: "What's your current CTC? This helps us match you with the right salary bracket in the UK. 💰" },
    {
      type: 'textinput',
      ph: 'Enter current CTC in LPA (e.g. 18)',
      cb: v => { window._answers.ctc = v; flowJobsResume(); }
    }
  ]);
}

function flowJobsResume() {
  enqueue([
    { type: 'typing', ms: 900 },
    { type: 'bot', html: "Last one! Upload your resume so I can personalise your roadmap and job matches. Totally optional 👇" },
    {
      type: 'upload',
      onUp:   (file) => flowAfterResume(file),
      onSkip: ()     => flowJobsResults()
    }
  ]);
}

function flowAfterResume(file) {
  const fname = file ? file.name : 'your resume';
  enqueue([
    { type: 'wait', ms: 400 },
    { type: 'typing', ms: 1300 },
    { type: 'bot', html: `Reading <b>${fname}</b>... extracting your profile ⚡` },
    { type: 'wait', ms: 900 },
    { type: 'typing', ms: 1100 },
    { type: 'bot', html: "Done! Here's what I found — tap to expand and edit if anything's off 👇" },
    { type: 'widget', html: buildProfileCard() },
    { type: 'wait', ms: 500 },
    { type: 'typing', ms: 800 },
    { type: 'bot', html: "Looks good? I'll use this to personalise your visa score and job matches." },
    {
      type: 'chips',
      opts: ['✅ Looks right, continue', '✏️ I want to edit first'],
      cb: c => {
        if (c.includes('edit')) {
          /* open the card for the user */
          const body = document.getElementById('profile-card-body');
          const icon = document.getElementById('profile-toggle-icon');
          if (body) { body.classList.add('open'); }
          if (icon) { icon.classList.add('open'); }
          enqueue([
            { type: 'bot', html: "Sure! Tap the ✏️ next to any field to update it, then hit continue." },
            {
              type: 'chips',
              opts: ['✅ Done, continue'],
              cb: () => flowJobsResults()
            }
          ]);
        } else {
          flowJobsResults();
        }
      }
    }
  ]);
}

/* ── Profile card builder ── */
function buildProfileCard() {
  const a = window._answers || {};
  const domain   = a.domain || 'Software Engineering';
  const exp      = a.experience || '6 years';
  const ctc      = a.ctc || '₹28 LPA';
  const country  = (a.country || 'UK').replace(/[🇬🇧🇮🇪🇦🇺🌍]/gu,'').trim();
  return `
    <div class="profile-card" id="profile-card">
      <div class="profile-card-header" onclick="toggleProfileCard()">
        <div class="profile-card-icon">✨</div>
        <div class="profile-card-text">
          <div class="profile-card-title">Your Profile Analysis</div>
          <div class="profile-card-subtitle">${domain} · ${exp} · ${ctc}</div>
        </div>
        <div class="profile-card-toggle" id="profile-toggle-icon">∨</div>
      </div>
      <div class="profile-card-body" id="profile-card-body">
        <div class="profile-row">
          <span class="profile-field-icon">🎯</span>
          <span class="profile-field-label">Domain</span>
          <span class="profile-field-value" id="pval-domain">${domain}</span>
          <button class="profile-edit-btn" onclick="editProfileField('domain','pval-domain')">✏️</button>
        </div>
        <div class="profile-row">
          <span class="profile-field-icon">⏳</span>
          <span class="profile-field-label">Experience</span>
          <span class="profile-field-value" id="pval-exp">${exp}</span>
          <button class="profile-edit-btn" onclick="editProfileField('exp','pval-exp')">✏️</button>
        </div>
        <div class="profile-row">
          <span class="profile-field-icon">💰</span>
          <span class="profile-field-label">CTC</span>
          <span class="profile-field-value" id="pval-ctc">${ctc}</span>
          <button class="profile-edit-btn" onclick="editProfileField('ctc','pval-ctc')">✏️</button>
        </div>
        <div class="profile-row">
          <span class="profile-field-icon">🎓</span>
          <span class="profile-field-label">Education</span>
          <span class="profile-field-value" id="pval-edu">B.Tech CSE · IIT Delhi</span>
          <button class="profile-edit-btn" onclick="editProfileField('edu','pval-edu')">✏️</button>
        </div>
        <div class="profile-skills-section">
          <div class="profile-skills-header">
            <span class="profile-field-icon">🛠</span>
            <span class="profile-field-label">Your Skills</span>
            <button class="profile-edit-btn" style="margin-left:auto" onclick="editSkillsNote()">✏️</button>
          </div>
          <div class="profile-chips">
            <span class="skill-chip">React</span>
            <span class="skill-chip">Node.js</span>
            <span class="skill-chip">Python</span>
            <span class="skill-chip">PostgreSQL</span>
            <span class="skill-chip">REST APIs</span>
            <span class="skill-chip">Git</span>
          </div>
        </div>
